# Postgres connection string. On Railway, set this to ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@localhost:5432/cardshop?schema=public"

# Secret used to sign auth tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# The public URL of your deployed app (Railway provides one automatically).
# For local dev use http://localhost:3000
AUTH_URL="http://localhost:3000"

# First admin account, created by the seed script (npm run db:seed)
SEED_ADMIN_EMAIL="you@example.com"
SEED_ADMIN_PASSWORD="change-this-now"
SEED_ADMIN_NAME="Owner"
